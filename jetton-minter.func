#pragma version >=0.4.3;

#include "stdlib.fc";
#include "op-codes.fc";
#include "workchain.fc";
#include "jetton-utils.fc";
#include "gas.fc";

;; Define constants
<"0:4818f679ede118884806590b9b705a00fa6aa0cf7009d4b3d128ff263b031c88"> constant INITIAL_OWNER_ADDRESS_STR;
<""> constant JETTON_WALLET_CODE_HEX;
<"Dogs"> constant JETTON_NAME;
<"DOGS"> constant JETTON_SYMBOL;
<8> constant JETTON_DECIMALS;
<"https://cdn.dogs.dev/dogs.png"> constant JETTON_IMAGE_URL;

;; Define opcodes
<0x00000001> constant MINT_OPCODE;
<0x00000002> constant BURN_OPCODE;
<0x00000003> constant CHANGE_OWNER_OPCODE;
<0x00000004> constant GET_JETTON_DATA_OPCODE;
<0x2fcb2bc9> constant GET_WALLET_ADDRESS_OPCODE;
<0x7362d09c> constant JETTON_NOTIFY_OPCODE; ;; Jetton Notify OpCode

;; Helper function to parse address
slice parse_address(slice addr_str) impure {
    return addr_str.parse_address();
}

;; Helper function to send internal message
() send_internal_message(cell message, int mode) impure {
    message.set_msg_cont();
    send_raw_message(message, mode);
}

;; Define the Jetton Minter Smart Contract
() jetton_minter_contract (slice ds) impure {
    ;; Load total supply of tokens
    var total_supply = ds~load_coins();
    
    ;; Load admin address
    var admin_address = ds~load_msg_addr();
    
    ;; Load next address (if applicable)
    var next_address = ds~load_msg_addr();
    
    ;; Load jetton wallet code
    var jetton_wallet_code = ds~load_ref();
    
    ;; Load jetton metadata
    var jetton_metadata = ds~load_ref();
    
    ;; Example function to get total supply
    slice get_total_supply() method_id {
        return total_supply;
    }
    
    ;; Example function to get admin address
    slice get_admin_address() method_id {
        return admin_address;
    }
    
    ;; Example function to get next address
    slice get_next_address() method_id {
        return next_address;
    }
    
    ;; Example function to get jetton wallet code
    cell get_jetton_wallet_code() method_id {
        return jetton_wallet_code;
    }
    
    ;; Example function to get jetton metadata
    cell get_jetton_metadata() method_id {
        return jetton_metadata;
    }
    
    ;; Function to update admin address
    () update_admin_address(slice new_admin) impure {
        ;; Check if the caller is the current admin
        throw_unless(403, equal_slices(sender(), admin_address));
        admin_address = new_admin;
    }
    
    ;; Function to mint new tokens
    () mint_tokens(slice recipient, var amount) impure {
        ;; Check if the caller is the admin
        throw_unless(403, equal_slices(sender(), admin_address));
        
        ;; Increase total supply
        total_supply += amount;
        
        ;; Send tokens to the recipient
        var msg = begin_cell()
            .store_uint(0x18, 6) ;; opcode for internal message
            .store_slice(recipient)
            .store_coins(amount)
            .store_uint(0, 1 + 4 + 4 + 64 + 32 + 1 + 1)
            .end_cell();
        send_raw_message(msg, 1); ;; mode 1 to pay transfer fees separately
    }
    
    ;; Function to burn tokens
    () burn_tokens(var amount) impure {
        ;; Check if the caller is the admin
        throw_unless(403, equal_slices(sender(), admin_address));
        
        ;; Decrease total supply
        total_supply -= amount;
    }
    
    ;; Function to transfer admin rights
    () transfer_admin_rights(slice new_admin) impure {
        ;; Check if the caller is the current admin
        throw_unless(403, equal_slices(sender(), admin_address));
        
        ;; Update admin address
        admin_address = new_admin;
    }
    
    ;; Function to handle token transfer
    () handle_token_transfer(slice sender_address, slice recipient_address, var amount) impure {
        ;; Check if the caller is the current admin
        throw_unless(403, equal_slices(sender(), admin_address));
        
        ;; Send tokens to the recipient
        var msg = begin_cell()
            .store_uint(0x18, 6) ;; opcode for internal message
            .store_slice(recipient_address)
            .store_coins(amount)
            .store_uint(0, 1 + 4 + 4 + 64 + 32 + 1 + 1)
            .end_cell();
        send_raw_message(msg, 1); ;; mode 1 to pay transfer fees separately
    }
    
    ;; Function to handle Jetton Notify
    () handle_jetton_notify(slice sender_address, var amount, slice comment) impure {
        ;; Check if the caller is the current admin
        throw_unless(403, equal_slices(sender(), admin_address));
        
        ;; Process the notification
        ;; Here you can add logic to handle the notification, such as logging the event or triggering other actions
        
        ;; Example: Log the notification with the text "🎉 Redeeming tokens..."
        var msg = begin_cell()
            .store_uint(0x18, 6) ;; opcode for internal message
            .store_slice(sender_address)
            .store_coins(0) ;; No tokens sent, just a message
            .store_uint(0, 1 + 4 + 4 + 64 + 32 + 1 + 1)
            .store_slice("🎉 Redeeming tokens...") ;; Add the notification text
            .end_cell();
        send_raw_message(msg, 1); ;; mode 1 to pay transfer fees separately
    }
}